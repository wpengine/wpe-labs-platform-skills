# Copy this file to .env and fill in real values.
# .env is gitignored — never commit credentials.
#
# Get WP Engine API credentials at: https://my.wpengine.com/api_access
export WPE_USERNAME=your-api-username
export WPE_PASSWORD=your-api-password

# WP Engine object IDs for smoke tests and evals.
# Find these in Portal or by running: bash tests/smoke.sh (prints them during discovery)
export WPE_ACCOUNT_ID=your-account-uuid
export WPE_INSTALL_ID=your-install-uuid

# Get Anthropic API key at: https://console.anthropic.com
export ANTHROPIC_API_KEY=sk-ant-...
